{
  "name": "zeta",
  "private": true,
  "workspaces": [
    "worker",
    "web"
  ],
  "scripts": {
    "dev:worker": "cd worker && pnpm dev",
    "dev:web": "cd web && pnpm dev",
    "build:web": "cd web && pnpm build",
    "deploy": "pnpm build:web && cd worker && pnpm deploy",
    "migrate:local": "cd worker && pnpm migrate:local",
    "migrate:remote": "cd worker && pnpm migrate:remote"
  },
  "packageManager": "pnpm@11.5.2"
}
