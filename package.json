{
  "name": "zeta",
  "private": true,
  "workspaces": [
    "worker",
    "web"
  ],
  "scripts": {
    "dev:worker": "cd worker && pnpm dev",
    "dev:web": "cd web && pnpm dev",
    "build": "pnpm build:web",
    "build:web": "cd web && pnpm build",
    "deploy": "pnpm build:web && cd worker && pnpm deploy",
    "migrate:local": "cd worker && pnpm migrate:local",
    "migrate:remote": "cd worker && pnpm migrate:remote",
    "lint": "biome lint .",
    "lint:fix": "biome lint --apply .",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "packageManager": "pnpm@11.6.0",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0"
  }
}
