{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 6am on monday"],
  "timezone": "UTC",
  "automerge": false,
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "groupName": "Cloudflare packages",
      "matchPackagePatterns": [
        "^@cloudflare/"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "groupName": "SimpleWebAuthn packages",
      "matchPackagePatterns": [
        "^@simplewebauthn/"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "groupName": "CodeMirror packages",
      "matchPackagePatterns": [
        "^@codemirror/",
        "^@uiw/react-codemirror$",
        "^codemirror$"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "groupName": "React ecosystem",
      "matchPackagePatterns": [
        "^react$",
        "^react-dom$",
        "^react-router-dom$"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "groupName": "Build tooling",
      "matchPackagePatterns": [
        "^typescript$",
        "^vite$",
        "^vitest$",
        "^@vitejs/plugin-react$",
        "^tailwindcss$",
        "^@tailwindcss/vite$"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    }
  ]
}
